# Copy to .env and fill in values. Never commit .env.
#
# Every variable is OPTIONAL — anything unset degrades to an in-memory stub
# with a startup warning, so the PoC always runs fully mocked.
# config/runtime.yaml names which variable each production client reads.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Jira / Confluence (read-only for client systems; write only for resolution records)
ATLASSIAN_BASE_URL=https://yourorg.atlassian.net
ATLASSIAN_USER=support-agent@yourorg.com
ATLASSIAN_API_TOKEN=...
ATLASSIAN_PROJECT_KEY=WH

# GitHub (read-only: base org + per-client orgs)
GITHUB_TOKEN=ghp_...
GITHUB_BASE_ORG=your-base-org
GITHUB_CLIENT_ORG_PREFIX=client-

# Salesforce (read-only)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=...

# AWS (read-only: S3 log buckets for S3-log-tier clients)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Teams bot (Azure Bot registration)
TEAMS_APP_ID=...
TEAMS_APP_PASSWORD=...
TEAMS_TENANT_ID=...

# State + audit stores: SQLite files for the PoC, configured in
# config/runtime.yaml (stores.state_db / stores.audit_db) — no env var needed.

# Vector store (pgvector — history search + resolution write-back)
VECTOR_STORE_DSN=postgresql://user:pass@localhost:5432/support_vectors

# Phoenix (internal — per-client connectivity resolver)
PHOENIX_BASE_URL=https://phoenix.internal
PHOENIX_API_TOKEN=...

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=support-orchestration
